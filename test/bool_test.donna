import bool
import test_should

pub fn not_true_test() -> String:
  bool.not(True) |> test_should.be_false()

pub fn not_false_test() -> String:
  bool.not(False) |> test_should.be_true()

pub fn and_tt_test() -> String:
  bool.and(True, True) |> test_should.be_true()

pub fn and_tf_test() -> String:
  bool.and(True, False) |> test_should.be_false()

pub fn and_ff_test() -> String:
  bool.and(False, False) |> test_should.be_false()

pub fn or_tt_test() -> String:
  bool.or(True, True) |> test_should.be_true()

pub fn or_tf_test() -> String:
  bool.or(True, False) |> test_should.be_true()

pub fn or_ff_test() -> String:
  bool.or(False, False) |> test_should.be_false()

pub fn xor_tt_test() -> String:
  bool.xor(True, True) |> test_should.be_false()

pub fn xor_tf_test() -> String:
  bool.xor(True, False) |> test_should.be_true()

pub fn xor_ff_test() -> String:
  bool.xor(False, False) |> test_should.be_false()

pub fn to_int_true_test() -> String:
  bool.to_int(True) |> test_should.equal_int(1)

pub fn to_int_false_test() -> String:
  bool.to_int(False) |> test_should.equal_int(0)

pub fn to_string_true_test() -> String:
  bool.to_string(True) |> test_should.equal_string("True")

pub fn to_string_false_test() -> String:
  bool.to_string(False) |> test_should.equal_string("False")

pub fn guard_true_test() -> String:
  bool.guard(True, 42, 0) |> test_should.equal_int(42)

pub fn guard_false_test() -> String:
  bool.guard(False, 42, 0) |> test_should.equal_int(0)
