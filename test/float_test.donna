import float
import test_should

pub fn equal_true_test() -> String:
  float.equal(1.5, 1.5) |> test_should.be_true()

pub fn equal_false_test() -> String:
  float.equal(1.5, 2.5) |> test_should.be_false()

pub fn near_true_test() -> String:
  float.near(3.141, 3.14, 0.01) |> test_should.be_true()

pub fn near_false_test() -> String:
  float.near(3.2, 3.14, 0.01) |> test_should.be_false()

pub fn near_negative_tolerance_false_test() -> String:
  float.near(3.14, 3.14, -0.1) |> test_should.be_false()

pub fn is_finite_true_test() -> String:
  float.is_finite(1.0) |> test_should.be_true()

pub fn sign_positive_test() -> String:
  float.sign(3.0) |> test_should.equal_int(1)

pub fn sign_negative_test() -> String:
  float.sign(-3.0) |> test_should.equal_int(-1)

pub fn sign_zero_test() -> String:
  float.sign(0.0) |> test_should.equal_int(0)
