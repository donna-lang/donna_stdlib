import files
import string
import test_should

// Uses /tmp/donna_stdlib_files_test as a scratch directory.
// Each test function creates or cleans up its own state.

// mkdir / is_dir

pub fn mkdir_creates_dir_test() -> String:
  let path = "/tmp/donna_stdlib_mkdir_test"
  let _ = shell_rm(path)
  let code = files.mkdir(path)
  let ok = code == 0
  let _ = shell_rm(path)
  ok |> test_should.be_true()

pub fn is_dir_true_test() -> String:
  let path = "/tmp/donna_stdlib_isdir_test"
  let _ = files.mkdir(path)
  let result = files.is_dir(path)
  let _ = shell_rm(path)
  result |> test_should.be_true()

pub fn is_dir_false_for_file_test() -> String:
  let path = "/tmp/donna_stdlib_isdir_file_test.txt"
  let _ = files.write(path, "x")
  let result = files.is_dir(path)
  let _ = files.delete(path)
  result |> test_should.be_false()

pub fn is_dir_missing_test() -> String:
  files.is_dir("/tmp/donna_stdlib_no_such_dir_xyz") |> test_should.be_false()

pub fn mkdir_all_creates_nested_dirs_test() -> String:
  let dir = "/tmp/donna_stdlib_mkdir_all/a/b/c"
  let _ = shell_rm("/tmp/donna_stdlib_mkdir_all")
  let code = files.mkdir_all(dir)
  let ok = files.is_dir(dir)
  let _ = shell_rm("/tmp/donna_stdlib_mkdir_all")
  case code == 0:
    True -> ok |> test_should.be_true()
    False -> test_should.fail("mkdir_all should return zero")

// write / read

pub fn write_read_test() -> String:
  let path = "/tmp/donna_stdlib_write_read.txt"
  let _ = files.write(path, "hello world")
  let content = files.read(path)
  let _ = files.delete(path)
  string.equal(content, "hello world") |> test_should.be_true()

pub fn write_returns_zero_test() -> String:
  let path = "/tmp/donna_stdlib_write_zero.txt"
  let code = files.write(path, "data")
  let _ = files.delete(path)
  code |> test_should.equal_int(0)

pub fn read_missing_returns_empty_test() -> String:
  files.read("/tmp/donna_stdlib_no_such_file_xyz.txt") |> test_should.equal_string("")

pub fn write_overwrite_test() -> String:
  let path = "/tmp/donna_stdlib_overwrite.txt"
  let _ = files.write(path, "first")
  let _ = files.write(path, "second")
  let content = files.read(path)
  let _ = files.delete(path)
  string.equal(content, "second") |> test_should.be_true()

// append

pub fn append_test() -> String:
  let path = "/tmp/donna_stdlib_append.txt"
  let _ = files.write(path, "hello")
  let _ = files.append(path, " world")
  let content = files.read(path)
  let _ = files.delete(path)
  string.equal(content, "hello world") |> test_should.be_true()

pub fn append_to_new_file_test() -> String:
  let path = "/tmp/donna_stdlib_append_new.txt"
  let _ = files.delete(path)
  let _ = files.append(path, "appended")
  let content = files.read(path)
  let _ = files.delete(path)
  string.equal(content, "appended") |> test_should.be_true()

// exists / is_file

pub fn exists_true_test() -> String:
  let path = "/tmp/donna_stdlib_exists.txt"
  let _ = files.write(path, "x")
  let result = files.exists(path)
  let _ = files.delete(path)
  result |> test_should.be_true()

pub fn exists_false_test() -> String:
  files.exists("/tmp/donna_stdlib_no_such_xyz.txt") |> test_should.be_false()

pub fn is_file_true_test() -> String:
  let path = "/tmp/donna_stdlib_isfile.txt"
  let _ = files.write(path, "x")
  let result = files.is_file(path)
  let _ = files.delete(path)
  result |> test_should.be_true()

pub fn is_file_false_for_dir_test() -> String:
  let path = "/tmp/donna_stdlib_isfile_dir"
  let _ = files.mkdir(path)
  let result = files.is_file(path)
  let _ = shell_rm(path)
  result |> test_should.be_false()

// delete

pub fn delete_removes_file_test() -> String:
  let path = "/tmp/donna_stdlib_delete.txt"
  let _ = files.write(path, "bye")
  let _ = files.delete(path)
  files.exists(path) |> test_should.be_false()

pub fn delete_missing_returns_nonzero_test() -> String:
  let code = files.delete("/tmp/donna_stdlib_no_such_file_xyz.txt")
  case code == 0:
    True -> test_should.fail("deleting missing file should return non-zero")
    False -> ""

pub fn remove_dir_removes_empty_dir_test() -> String:
  let dir = "/tmp/donna_stdlib_remove_dir"
  let _ = shell_rm(dir)
  let _ = files.mkdir(dir)
  let code = files.remove_dir(dir)
  case code == 0:
    True -> files.exists(dir) |> test_should.be_false()
    False -> test_should.fail("remove_dir should return zero")

pub fn remove_all_removes_nested_tree_test() -> String:
  let dir = "/tmp/donna_stdlib_remove_all"
  let nested = dir <> "/a/b"
  let _ = shell_rm(dir)
  let _ = files.mkdir_all(nested)
  let _ = files.write(nested <> "/file.txt", "x")
  let code = files.remove_all(dir)
  case code == 0:
    True -> files.exists(dir) |> test_should.be_false()
    False -> test_should.fail("remove_all should return zero")

// copy

pub fn copy_test() -> String:
  let src = "/tmp/donna_stdlib_copy_src.txt"
  let dst = "/tmp/donna_stdlib_copy_dst.txt"
  let _ = files.write(src, "copied content")
  let _ = files.copy(src, dst)
  let content = files.read(dst)
  let _ = files.delete(src)
  let _ = files.delete(dst)
  string.equal(content, "copied content") |> test_should.be_true()

pub fn copy_independent_test() -> String:
  let src = "/tmp/donna_stdlib_copy_ind_src.txt"
  let dst = "/tmp/donna_stdlib_copy_ind_dst.txt"
  let _ = files.write(src, "original")
  let _ = files.copy(src, dst)
  let _ = files.delete(src)
  let content = files.read(dst)
  let _ = files.delete(dst)
  string.equal(content, "original") |> test_should.be_true()

pub fn rename_test() -> String:
  let src = "/tmp/donna_stdlib_rename_src.txt"
  let dst = "/tmp/donna_stdlib_rename_dst.txt"
  let _ = files.delete(src)
  let _ = files.delete(dst)
  let _ = files.write(src, "renamed")
  let code = files.rename(src, dst)
  let content = files.read(dst)
  let src_exists = files.exists(src)
  let _ = files.delete(dst)
  case code == 0:
    True ->
      test_should.be_false(src_exists) <> test_should.equal_string(content, "renamed")
    False -> test_should.fail("rename should return zero")

// list_dir

pub fn list_dir_test() -> String:
  let dir = "/tmp/donna_stdlib_listdir"
  let _ = shell_rm(dir)
  let _ = files.mkdir(dir)
  let _ = files.write(dir <> "/a.txt", "a")
  let _ = files.write(dir <> "/b.txt", "b")
  let entries = files.list_dir(dir)
  let has_a = list_contains(entries, "a.txt")
  let has_b = list_contains(entries, "b.txt")
  let _ = files.delete(dir <> "/a.txt")
  let _ = files.delete(dir <> "/b.txt")
  let _ = shell_rm(dir)
  test_should.be_true(has_a) <> test_should.be_true(has_b)

pub fn list_dir_empty_test() -> String:
  let dir = "/tmp/donna_stdlib_listdir_empty"
  let _ = shell_rm(dir)
  let _ = files.mkdir(dir)
  let entries = files.list_dir(dir)
  let _ = shell_rm(dir)
  case entries:
    [] -> ""
    _ -> test_should.fail("expected empty listing")

pub fn read_lines_test() -> String:
  let path = "/tmp/donna_stdlib_read_lines.txt"
  let _ = files.write(path, "one\ntwo\nthree")
  let lines = files.read_lines(path)
  let _ = files.delete(path)
  case lines:
    ["one", "two", "three"] -> ""
    _ -> test_should.fail("expected three lines")

// ── Helpers ───────────────────────────────────────────────────────────────────

// Remove a directory (or file) using shell, ignoring errors.
fn shell_rm(path: String) -> Int:
  run_cmd("rm -rf " <> path)

@external("c", "donna_ffi_shell_exec")
fn run_cmd(cmd: String) -> Int

fn list_contains(xs: List(String), s: String) -> Bool:
  case xs:
    [] -> False
    [x, ..rest] ->
      case string_equal(x, s):
        True -> True
        False -> list_contains(rest, s)
